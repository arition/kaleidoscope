{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": ["typescript", "unicorn", "oxc"],
  "categories": {
    "correctness": "error"
  },
  "env": {
    "builtin": true
  },
  "options": {
    "denyWarnings": true,
    "reportUnusedDisableDirectives": "error",
    "typeAware": true
  },
  "overrides": [
    {
      "files": [
        "frontend/**/*.ts",
        "tests/frontend/**/*.ts",
        "tests/e2e/**/*.{ts,js}",
        "benchmarks/browser.ts"
      ],
      "env": {
        "browser": true
      }
    },
    {
      "files": ["tests/e2e/**/*.mjs", "benchmarks/**/*.mjs", "*.config.ts"],
      "env": {
        "node": true
      }
    }
  ]
}
