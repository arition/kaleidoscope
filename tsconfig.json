{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "noEmit": true,
    "verbatimModuleSyntax": true,
    "skipLibCheck": true
  },
  "include": [
    "benchmarks/**/*.ts",
    "frontend/**/*.ts",
    "tests/frontend/**/*.ts",
    "tests/e2e/**/*.ts",
    "playwright.config.ts",
    "vitest.config.ts"
  ]
}
